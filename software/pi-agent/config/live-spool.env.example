# Optional overrides. Copy to /etc/filamenttracker-live-spool/live-spool.env.
LIVE_SPOOL_CONFIG_FILE=/etc/filamenttracker-live-spool/config.yaml
LIVE_SPOOL_DATA_DIR=/var/lib/filamenttracker-live-spool
LIVE_SPOOL_DEVICE_NAME=Live Spool
LIVE_SPOOL_API_HOST=0.0.0.0
LIVE_SPOOL_API_PORT=8001
LIVE_SPOOL_LOG_LEVEL=info
# LIVE_SPOOL_SCALE_BACKEND=nau7802
# LIVE_SPOOL_HX711_DATA_PIN=5
# LIVE_SPOOL_HX711_CLOCK_PIN=6
# LIVE_SPOOL_NAU7802_ADDRESS=0x2A
# LIVE_SPOOL_PN532_ADDRESS=0x24
LIVE_SPOOL_DEVELOPMENT_MODE=false
LIVE_SPOOL_MOCK_HARDWARE=false
LIVE_SPOOL_SYSTEM_CONTROLS_ENABLED=false
